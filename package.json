{
  "name": "rocket",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:api": "bun run --filter @rocket/api dev",
    "dev:web": "bun run --filter @rocket/web dev",
    "build": "bun run --filter @rocket/web build",
    "docker:build": "docker build -t rocket .",
    "docker:run": "docker run --rm -p 3001:3001 rocket",
    "docker:up": "docker compose up --build",
    "test": "echo \"No tests specified\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3"
  }
}
